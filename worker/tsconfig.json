{
  "compilerOptions": {
    // ─ Target ─────────────────────────────────────────────────────
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",

    // ─ Types ────────────────────────────────────────────────────
    // NOTE: "node" is required for node:crypto / node:buffer (nodejs_compat flag)
    "types": ["@cloudflare/workers-types", "node"],

    // ─ Output ─────────────────────────────────────────────────────────────────
    // outDir is kept so `tsc` without --noEmit doesn't pollute src/
    // declaration is NOT needed — this project is a Worker, not a published library
    "rootDir": "./src",
    "outDir": "./dist",

    // ─ Strict mode ────────────────────────────────────────────────────────────
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    // exactOptionalPropertyTypes: true — recommended future improvement
    // Requires updating optional fields in: action-schema.ts, pipeline.ts, agent-context.ts,
    // orchestrator.ts, 10-action-router.ts, 17-notification.ts, routes/chat.ts, routes/auth.ts

    // ─ Interop ─────────────────────────────────────────────────
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
