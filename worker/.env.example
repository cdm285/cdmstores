# Variáveis de ambiente do backend CDM Stores
# Copie este arquivo para .env.local — NUNCA comite o arquivo com valores reais

# ── Aplicação ──────────────────────────────────────────────
APP_URL=https://cdmstores.com

# ── Segurança ──────────────────────────────────────────────
# String aleatória longa e única. Gere com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_at_least_64_bytes_hex

# Chave de acesso à API de administração (criação de produtos, etc.)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=your_admin_key_here

# ── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Obtido em: Stripe Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ─────────────────────────────────────────
# Obtido em: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── CJdropshipping ─────────────────────────────────────────
CJ_API_KEY=your_cj_api_key_here
CJ_API_SECRET=your_cj_api_secret_here

# ── OAuth (opcional) ───────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# ── Banco de dados ─────────────────────────────────────────
DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Ambiente ───────────────────────────────────────────────
ENVIRONMENT=development
