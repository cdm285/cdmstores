# CDM STORES — Environment secrets reference
# ─────────────────────────────────────────────────────────────────────────────
# DO NOT commit actual secrets. Set them with:
#   wrangler secret put <KEY> --env production
#
# Bindings (D1, AI, Vectorize, KV) are declared in wrangler.toml — not here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY is a public key — safe to commit in frontend code,
# but set as a secret here if you want it accessible in the Worker env.
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Authentication ────────────────────────────────────────────────────────────
# Min 64 characters. Generate with:
#   PowerShell: [Convert]::ToBase64String((1..64 | % { Get-Random -Max 256 }))
#   Node: require('crypto').randomBytes(64).toString('base64')
JWT_SECRET=change-me-to-at-least-64-random-chars

# ── Organic traffic admin guard ───────────────────────────────────────────────
# Shared secret for X-Organic-Key header (POST /api/organic/*).
# Must be DIFFERENT from JWT_SECRET — use the same generation method above.
ORGANIC_SECRET=change-me-different-from-jwt-secret

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Application URL ───────────────────────────────────────────────────────────
# Used in email links (password reset, email verify). No trailing slash.
APP_URL=https://cdmstores.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Only GOOGLE_CLIENT_ID is needed — auth uses idToken/accessToken validation,
# not the server-side authorization code flow.
GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# ── Facebook OAuth ────────────────────────────────────────────────────────────
FACEBOOK_APP_ID=...
FACEBOOK_APP_SECRET=...

# ── Cloudflare Turnstile (bot protection) ─────────────────────────────────────
TURNSTILE_SECRET_KEY=...

# ── Runtime (set via wrangler.toml [vars], not as a secret) ──────────────────
ENVIRONMENT=production
