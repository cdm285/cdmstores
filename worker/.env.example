# Variáveis de ambiente do backend
# Copiar para .env local (não commitar)

# API
API_URL=https://api.cdmstores.com

# Stripe
STRIPE_SECRET_KEY=your_stripe_test_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_test_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=your_stripe_test_publishable_key_here

# Banco de dados
DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Ambiente
ENVIRONMENT=development
