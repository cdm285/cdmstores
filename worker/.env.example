# CDM STORES — Required environment secrets
# Copy this file to .env (never commit .env to git)
# Set these via `wrangler secret put <KEY>` for production

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Authentication ────────────────────────────────────────────────────────────
# JWT signing secret — min 32 chars, random bytes recommended
JWT_SECRET=change-me-to-at-least-32-random-chars

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# ── Facebook OAuth ────────────────────────────────────────────────────────────
FACEBOOK_APP_ID=...
FACEBOOK_APP_SECRET=...

# ── Cloudflare Turnstile (bot protection) ─────────────────────────────────────
TURNSTILE_SECRET_KEY=...

# ── D1 Database (Cloudflare — set in wrangler.toml, not as secret) ────────────
DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Runtime ────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
